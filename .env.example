# Runtime
NODE_ENV=development
IQ_APP_NAME=LifeShack IQ
IQ_RUNTIME_MODE=local
IQ_TIMEZONE=America/Los_Angeles
IQ_ENABLE_SCHEDULED_PRODUCTION_WORKFLOWS=false

# SQLite
DATABASE_PATH=./data/iq.sqlite

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
IQ_DAILY_UPDATE_CHANNEL_ID=
IQ_CRITICAL_ALERT_CHANNEL_ID=
IQ_WEEKLY_REFLECTION_CHANNEL_ID=

# Agent
IQ_AGENT_MODE=openai
IQ_OPENAI_MODEL=gpt-5.5
IQ_OPENAI_REASONING_EFFORT=low
IQ_OPENAI_VERBOSITY=low
IQ_OPENAI_MAX_OUTPUT_TOKENS=1200
IQ_OPENAI_TIMEOUT_MS=60000
IQ_OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Connector hardening
IQ_CONNECTOR_TIMEOUT_MS=5000
IQ_CONNECTOR_RETRIES=1

# Local read-only exports for end-to-end fixture mode
IQ_DATA_PROFILE=good
IQ_STRIPE_EXPORT_PATH=./src/data/fixtures/revenue-normal.json
IQ_POSTHOG_EXPORT_PATH=./src/data/fixtures/application-quality-good.json
IQ_AWS_OPS_EXPORT_PATH=./src/data/fixtures/daily-ops-good.json
IQ_SLACK_CONTEXT_PATH=
IQ_GRANOLA_NOTES_DIR=

# Live read-only connector mode
IQ_STRIPE_LIVE_ENABLED=false
IQ_STRIPE_LIVE_URL=
IQ_POSTHOG_LIVE_ENABLED=false
IQ_POSTHOG_LIVE_URL=
IQ_AWS_OPS_LIVE_ENABLED=false
IQ_AWS_OPS_LIVE_URL=
IQ_INTERNAL_OPS_URL=
IQ_INTERNAL_OPS_TOKEN=
IQ_SLACK_CONTEXT_LIVE_ENABLED=false
IQ_SLACK_CONTEXT_CHANNELS=
IQ_SLACK_CONTEXT_LIMIT=20

# Optional backups and provider credentials
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=lifeshack-iq/sqlite
AWS_PROFILE=
POSTHOG_API_KEY=
STRIPE_SECRET_KEY=
